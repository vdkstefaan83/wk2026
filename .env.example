# ----- App -----
APP_NAME="WK2026 Predictions"
APP_ENV=production
APP_DEBUG=false
APP_URL=https://wk2026.psb.ugent.be
APP_TIMEZONE=Europe/Brussels
APP_SECRET=change-me-to-a-long-random-string

# ----- Database -----
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=wk2026
DB_USER=wk2026
DB_PASS=
DB_CHARSET=utf8mb4

# ----- Mail (PHPMailer / SMTP) -----
MAIL_HOST=smtp.ugent.be
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=wk2026@psb.ugent.be
MAIL_FROM_NAME="WK2026 Pool"
MAIL_ADMIN_ADDRESS=wk2026@psb.ugent.be

# ----- Keycloak / OIDC -----
KEYCLOAK_ENABLED=false
KEYCLOAK_BASE_URL=https://keycloak.example.com
KEYCLOAK_REALM=master
KEYCLOAK_CLIENT_ID=wk2026
KEYCLOAK_CLIENT_SECRET=
KEYCLOAK_REDIRECT_URI=https://wk2026.psb.ugent.be/auth/keycloak/callback
KEYCLOAK_SCOPES="openid profile email"

# ----- API-Football (live scores) -----
# Get a key at https://www.api-football.com (free tier: 100 calls/day).
API_FOOTBALL_KEY=
API_FOOTBALL_BASE_URL=https://v3.football.api-sports.io
API_FOOTBALL_VIA_RAPIDAPI=false
API_FOOTBALL_LEAGUE_ID=1
API_FOOTBALL_SEASON=2026
API_FOOTBALL_TOPSCORER_INTERVAL_HOURS=1

# ----- Storage paths -----
STORAGE_PATH=storage
PDF_PATH=storage/pdfs
LOG_PATH=storage/logs
