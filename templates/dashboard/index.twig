{% extends 'layout/base.twig' %}
{% block title %}Dashboard · {{ app.name }}{% endblock %}
{% block content %}

<div class="flex flex-wrap items-center justify-between gap-3 mb-6">
  <div>
    <p class="text-xs uppercase tracking-widest text-slate-500 font-bold">Dashboard</p>
    <h1 class="font-display text-4xl font-extrabold mt-1 text-slate-900">My predictions</h1>
  </div>
  <a href="{{ url('/predictions/new') }}" class="btn btn-primary">+ New prediction</a>
</div>

{% if forms is empty %}
  <div class="card p-12 text-center">
    <div class="text-6xl mb-4">⚽</div>
    <h2 class="font-display text-2xl font-extrabold text-slate-900">No predictions yet</h2>
    <p class="text-slate-600 mt-2 max-w-md mx-auto">Create your first prediction and see how far you can take it toward becoming world champion.</p>
    <a href="{{ url('/predictions/new') }}" class="btn btn-primary mt-6">Start now →</a>
  </div>
{% else %}
  <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5 mb-10">
    {% for f in forms %}
      <div class="card card-hover overflow-hidden flex flex-col">
        <div class="{% if f.status == 'submitted' %}banner banner-green{% else %}banner banner-orange{% endif %} rounded-none rounded-t-[18px] px-5 py-3 text-sm">
          <span class="text-base">{% if f.status == 'submitted' %}✅{% else %}✏️{% endif %}</span>
          <span>{% if f.status == 'submitted' %}SUBMITTED{% else %}DRAFT{% endif %}</span>
        </div>
        <div class="p-5 flex-1 flex flex-col">
          <div class="font-display font-extrabold text-xl text-slate-900 truncate">{{ f.label }}</div>
          <div class="text-xs text-slate-500 mt-1">created {{ f.created_at|date('Y-m-d H:i') }}</div>

          <div class="mt-4 flex items-center gap-2 flex-wrap">
            {% if f.paid_at %}
              <span class="pill pill-green">💰 Paid · {{ f.paid_at|date('Y-m-d') }}</span>
            {% elseif f.status == 'submitted' %}
              <span class="pill pill-orange">⏳ Awaiting payment</span>
            {% endif %}
            {% if f.status == 'submitted' and f.score is defined %}
              <span class="ml-auto stat-number text-3xl text-emerald-600">{{ f.score }}<span class="text-sm text-slate-400 font-bold ml-1">pt</span></span>
            {% endif %}
          </div>

          <div class="flex gap-2 mt-5 pt-4 border-t border-slate-100">
            <a href="{{ url('/predictions/' ~ f.id) }}" class="btn btn-primary btn-sm flex-1">
              {{ f.status == 'submitted' ? '👁 View' : '✏️ Edit' }}
            </a>
            {% if f.status == 'submitted' %}
              <a href="{{ url('/predictions/' ~ f.id ~ '/pdf') }}" target="_blank" class="btn btn-secondary btn-sm">📄 PDF</a>
              <form method="post" action="{{ url('/predictions/' ~ f.id ~ '/delete') }}"
                    onsubmit="return confirm('Delete this SUBMITTED entry &quot;{{ f.label|e('js') }}&quot;? This is permanent and cannot be undone.')">
                <input type="hidden" name="_csrf" value="{{ csrf }}">
                <button class="btn btn-danger btn-sm">🗑</button>
              </form>
            {% else %}
              <form method="post" action="{{ url('/predictions/' ~ f.id ~ '/delete') }}" onsubmit="return confirm('Delete draft?')">
                <input type="hidden" name="_csrf" value="{{ csrf }}">
                <button class="btn btn-danger btn-sm">Delete</button>
              </form>
            {% endif %}
          </div>
        </div>
      </div>
    {% endfor %}
  </div>
{% endif %}

{# ---------- Public leaderboard ---------- #}
{% if leaderboard is not empty %}
  <div class="mt-4">
    <div class="flex items-end justify-between mb-4">
      <div>
        <p class="text-xs uppercase tracking-widest text-slate-500 font-bold">Standings</p>
        <h2 class="font-display text-3xl font-extrabold text-slate-900 mt-1">Leaderboard 🏆</h2>
      </div>
      <p class="text-xs text-slate-500">Only paid entries qualify for prizes.</p>
    </div>

    <div class="card overflow-hidden">
      <table class="w-full text-sm">
        <thead class="bg-slate-50 border-b-2 border-slate-100">
          <tr class="text-xs uppercase tracking-wider text-slate-500 font-bold">
            <th class="p-3 text-left w-16">#</th>
            <th class="p-3 text-left">User</th>
            <th class="p-3 text-left">Form</th>
            <th class="p-3 text-right">Score</th>
          </tr>
        </thead>
        <tbody>
          {% for r in leaderboard %}
            <tr class="border-t border-slate-100 {{ r.user_id == user_id ? 'bg-emerald-50' : '' }}">
              <td class="p-3 font-display font-extrabold text-center">
                {% if r.rank == 1 %}<span class="text-2xl">🥇</span>
                {% elseif r.rank == 2 %}<span class="text-2xl">🥈</span>
                {% elseif r.rank == 3 %}<span class="text-2xl">🥉</span>
                {% else %}<span class="text-slate-500">{{ r.rank }}</span>
                {% endif %}
              </td>
              <td class="p-3">
                <span class="font-semibold {{ r.user_id == user_id ? 'text-emerald-800' : 'text-slate-900' }}">
                  {{ r.user_name }}
                </span>
                {% if r.user_id == user_id %}
                  <span class="pill pill-green ml-2">you</span>
                {% endif %}
              </td>
              <td class="p-3 text-slate-700">{{ r.label }}</td>
              <td class="p-3 text-right stat-number text-2xl text-emerald-600">{{ r.score }}</td>
            </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  </div>
{% elseif forms is not empty %}
  <div class="card p-6 text-center mt-4">
    <div class="text-3xl mb-2">📊</div>
    <h3 class="font-display font-bold text-slate-900">Leaderboard coming soon</h3>
    <p class="text-sm text-slate-600 mt-1">As soon as the first matches are played and paid entries roll in, the standings will appear here.</p>
  </div>
{% endif %}

<div class="mt-8">
  {% include 'partials/prizes.twig' %}
</div>
{% endblock %}
