{% extends 'layout/base.twig' %}
{% block title %}Leaderboard · {{ app.name }}{% endblock %}
{% block content %}

<div class="flex flex-wrap items-center justify-between gap-3 mb-6">
  <div>
    <p class="text-xs uppercase tracking-widest text-slate-500 font-bold">Standings</p>
    <h1 class="font-display text-4xl font-extrabold mt-1 text-slate-900">Leaderboard 🏆</h1>
  </div>
  <p class="text-xs text-slate-500">Only paid entries qualify for prizes.</p>
</div>

{% if correct_tiebreak %}
  <p class="text-sm text-slate-600 mb-3 flex items-center gap-2">
    <span class="pill pill-blue">🎲 Tiebreaker: {{ correct_tiebreak }}</span>
    <span>tied scores are broken by smallest deviation.</span>
  </p>
{% endif %}

{% if rows is empty %}
  <div class="card p-12 text-center">
    <div class="text-5xl mb-4">📊</div>
    <h2 class="font-display text-2xl font-extrabold text-slate-900">No standings yet</h2>
    <p class="text-slate-600 mt-2 max-w-md mx-auto">
      The leaderboard becomes available once the first paid entries roll in and matches are played.
    </p>
  </div>
{% else %}
  <div class="card overflow-hidden">
    <table class="w-full text-sm">
      <thead class="bg-slate-50 border-b-2 border-slate-100">
        <tr class="text-xs uppercase tracking-wider text-slate-500 font-bold">
          <th class="p-3 text-left w-16">#</th>
          <th class="p-3 text-left">User</th>
          <th class="p-3 text-left">Form</th>
          <th class="p-3 text-right">Score</th>
        </tr>
      </thead>
      <tbody>
        {% for r in rows %}
          <tr class="border-t border-slate-100 hover:bg-slate-50 cursor-pointer transition {{ r.user_id == my_user_id ? 'bg-emerald-50 hover:bg-emerald-100' : '' }}"
              onclick="window.location='{{ url('/leaderboard/' ~ r.id) }}'">
            <td class="p-3 font-display font-extrabold text-center">
              {% if r.rank == 1 %}<span class="text-2xl">🥇</span>
              {% elseif r.rank == 2 %}<span class="text-2xl">🥈</span>
              {% elseif r.rank == 3 %}<span class="text-2xl">🥉</span>
              {% else %}<span class="text-slate-500">{{ r.rank }}</span>
              {% endif %}
            </td>
            <td class="p-3">
              <a href="{{ url('/leaderboard/' ~ r.id) }}"
                 onclick="event.stopPropagation()"
                 class="font-semibold hover:underline {{ r.user_id == my_user_id ? 'text-emerald-800' : 'text-slate-900' }}">
                {{ r.user_name }}
              </a>
              {% if r.user_id == my_user_id %}
                <span class="pill pill-green ml-2">you</span>
              {% endif %}
            </td>
            <td class="p-3 text-slate-700">{{ r.label }}</td>
            <td class="p-3 text-right stat-number text-2xl text-emerald-600">{{ r.score }}</td>
          </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
{% endif %}

<div class="mt-8">
  {% include 'partials/prizes.twig' %}
</div>
{% endblock %}
