{% extends 'layout/base.twig' %}
{% block title %}Nieuwe voorspelling · {{ app.name }}{% endblock %}
{% block content %}
<div class="max-w-md mx-auto bg-white rounded-xl shadow-sm border border-slate-200 p-6">
  <h1 class="text-2xl font-bold mb-4">Nieuwe voorspelling</h1>
  <form method="post" action="{{ url('/predictions/new') }}" class="space-y-4">
    <input type="hidden" name="_csrf" value="{{ csrf }}">
    <div>
      <label class="text-sm font-medium">Naam van het formulier</label>
      <input name="label" type="text" required value="Mijn voorspelling"
             class="mt-1 w-full rounded border-slate-300 focus:border-indigo-500 focus:ring-indigo-500">
      <p class="text-xs text-slate-500 mt-1">Bijv. "Mijn hoofdformulier", "Voor mijn zoon", …</p>
    </div>
    <button class="w-full px-4 py-2.5 rounded-lg bg-indigo-600 text-white hover:bg-indigo-700">Aanmaken</button>
  </form>
</div>
{% endblock %}
