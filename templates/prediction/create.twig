{% extends 'layout/base.twig' %}
{% block title %}Nieuwe voorspelling · {{ app.name }}{% endblock %}
{% block content %}
<div class="max-w-md mx-auto mt-10">
  <div class="card-thick p-8">
    <div class="banner banner-green mb-6">
      <span class="text-2xl">⚽</span>
      <span>Nieuwe voorspelling</span>
    </div>
    <p class="text-slate-600">Geef je formulier een naam zodat je het kan onderscheiden van de rest.</p>

    <form method="post" action="{{ url('/predictions/new') }}" class="space-y-5 mt-6">
      <input type="hidden" name="_csrf" value="{{ csrf }}">
      <div>
        <label class="field-label">📝 Naam van het formulier</label>
        <input name="label" type="text" required value="Mijn voorspelling" placeholder="Bv. Mijn hoofdformulier">
        <span class="field-hint">Bijv. "Mijn hoofdformulier", "Voor mijn zoon", …</span>
      </div>
      <button class="btn btn-primary w-full">Aanmaken →</button>
    </form>
  </div>
</div>
{% endblock %}
