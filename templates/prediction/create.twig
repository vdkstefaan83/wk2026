{% extends 'layout/base.twig' %}
{% block title %}Nieuwe voorspelling · {{ app.name }}{% endblock %}
{% block content %}
<div class="max-w-md mx-auto mt-10">
  <div class="glass rounded-3xl p-8 relative overflow-hidden">
    <div class="absolute -top-10 -right-10 w-32 h-32 rounded-full bg-lime-400/15 blur-3xl pointer-events-none"></div>
    <h1 class="font-display text-3xl font-extrabold text-slate-100">Nieuwe voorspelling</h1>
    <p class="text-sm text-slate-400 mt-1">Geef je formulier een naam zodat je het kan onderscheiden van de rest.</p>

    <form method="post" action="{{ url('/predictions/new') }}" class="space-y-4 mt-6">
      <input type="hidden" name="_csrf" value="{{ csrf }}">
      <div>
        <label class="text-xs uppercase tracking-wider font-medium">Naam van het formulier</label>
        <input name="label" type="text" required value="Mijn voorspelling" class="mt-1 w-full px-3 py-2.5">
        <p class="text-xs text-slate-500 mt-2">Bijv. "Mijn hoofdformulier", "Voor mijn zoon", …</p>
      </div>
      <button class="btn-neon w-full">Aanmaken →</button>
    </form>
  </div>
</div>
{% endblock %}
