{% extends 'layout/base.twig' %}
{% block title %}{{ form.label }} · {{ app.name }}{% endblock %}

{% block head %}
  {# Load prediction.js BEFORE Alpine so x-data="predictionWizard(...)" resolves. #}
  <script defer src="{{ asset('js/prediction.js') }}"></script>
{% endblock %}

{% block content %}
<script>
  // Fallback so the wizard still renders if prediction.js fails to load.
  if (typeof window.predictionWizard !== 'function') {
    window.predictionWizard = function (cfg) {
      return {
        step: 'groups',
        readonly: cfg.readonly,
        label: '',
        winnerTeamId: '',
        topscorerPlayerId: '',
        topscorerSearch: '',
        standings: cfg.initial.standings || {},
        bracket:   cfg.initial.bracket   || { r32: [] },
        downstream:cfg.initial.downstream|| { r16: [], qf: [], sf: [], final: { feeds: [] } },
        picks:     cfg.initial.picks     || {},
        lastSavedLabel: 'JS niet geladen',
        init() {},
        onScoreChange() {},
        pickSlot() {},
        autosave() {},
        save()  { document.getElementById('prediction-form').submit(); },
        isGroupsComplete() { return false; },
        matchesForStage() { return []; },
        slotsForStage() { return []; },
        completionForGroup() { return ''; },
        countPicks() { return 0; },
        groupCompletion() { return { filled: 0, total: 72 }; },
        get filteredPlayers() { return (window.__players || []).slice(0, 200); },
        get winnerLabel() { return ''; },
        get topscorerLabel() { return ''; },
      };
    };
    console.warn('prediction.js fallback geactiveerd – live ranking + autosave werken niet.');
  }
</script>
{% set readonly = form.status == 'submitted' %}
<script>
  // Wizard config moved out of x-data so JSON quotes don't break the HTML attribute.
  window.__wizardConfig = {
    formId: {{ form.id }},
    csrf: {{ csrf|json_encode|raw }},
    readonly: {{ readonly ? 'true' : 'false' }},
    initial: {
      standings:           {{ resolved.standings|json_encode|raw }},
      bracket:             {{ resolved.bracket|json_encode|raw }},
      downstream:          {{ resolved.downstream|json_encode|raw }},
      picks:               {{ resolved.picks|json_encode|raw }},
      topscorerPlayerId:   {{ form.topscorer_player_id ? form.topscorer_player_id : 'null' }},
      topscorerCustomName: {{ (form.topscorer_custom_name ?? '')|json_encode|raw }}
    }
  };
</script>
<div x-data="predictionWizard(window.__wizardConfig)"
     x-init="init()"
     class="space-y-6">

  <div class="card p-5 sm:p-6 flex flex-wrap items-center justify-between gap-4">
    <div class="min-w-0 flex-1">
      <p class="text-xs uppercase tracking-widest text-slate-500 font-bold">Voorspelling</p>
      <h1 class="font-display text-2xl sm:text-3xl font-extrabold mt-1 text-slate-900">
        <input x-model="label" @change="autosave()" :disabled="readonly"
               class="bg-transparent border-2 border-dashed border-slate-200 hover:border-slate-300 focus:border-emerald-400 focus:bg-emerald-50/30 rounded-xl px-2 py-1 -ml-2 max-w-md"
               value="{{ form.label }}">
      </h1>
      <p class="text-xs mt-3 flex flex-wrap items-center gap-2">
        {% if readonly %}
          <span class="pill pill-green">✅ Verzonden</span>
          <span class="text-slate-500">op {{ form.submitted_at|date('d/m/Y H:i') }}</span>
        {% else %}
          <span class="pill pill-orange">✏️ Concept</span>
          <span class="text-slate-500">laatste autosave: <span class="text-slate-700 font-semibold" x-text="lastSavedLabel"></span></span>
        {% endif %}
        {% if deadline %}<span class="text-slate-400">·</span><span class="text-slate-500">deadline: <span class="text-slate-700 font-semibold">{{ deadline }}</span></span>{% endif %}
      </p>
    </div>
    <div class="flex gap-2 text-sm">
      <a href="{{ url('/dashboard') }}" class="btn btn-secondary btn-sm">← Dashboard</a>
      {% if not readonly %}
        <button type="button" @click="save()" class="btn btn-secondary btn-sm">💾 Bewaren</button>
      {% else %}
        <a href="{{ url('/predictions/' ~ form.id ~ '/pdf') }}" target="_blank" class="btn btn-primary btn-sm">📄 PDF</a>
      {% endif %}
    </div>
  </div>

  {# Step tabs #}
  <div class="card p-2 flex flex-wrap gap-0 overflow-x-auto">
    {% for step in [
      {key:'groups',    label:'⚽ Groepsfase'},
      {key:'r32',       label:'1/16'},
      {key:'r16',       label:'1/8'},
      {key:'qf',        label:'1/4'},
      {key:'sf',        label:'1/2'},
      {key:'final',     label:'🏆 Finale'},
      {key:'topscorer', label:'👟 Topscorer'},
      {key:'summary',   label:'📋 Samenvatting'}
    ] %}
      <button type="button" @click="step='{{ step.key }}'"
              :class="step==='{{ step.key }}' ? 'is-active' : ''"
              class="tab-btn whitespace-nowrap">{{ step.label }}</button>
    {% endfor %}
  </div>

  <form method="post" id="prediction-form" action="{{ url('/predictions/' ~ form.id ~ '/save') }}">
    <input type="hidden" name="_csrf" value="{{ csrf }}">
    <input type="hidden" name="label" x-model="label">
    <input type="hidden" name="winner_team_id" x-model="winnerTeamId">
    <input type="hidden" name="topscorer_player_id" x-model="topscorerPlayerId">
    <input type="hidden" name="topscorer_custom_name" :value="topscorerCustomName">
    <input type="hidden" name="tiebreaker_value" x-model="tiebreakerValue">

    {# ---------------- Group stage ---------------- #}
    <section x-show="step==='groups'" class="space-y-5">
      <div class="banner banner-green">
        <span class="text-2xl">⚽</span>
        <span>Vul de scores in — de ranking past zich live aan</span>
      </div>

      {% for g in groups %}
        <div class="card overflow-hidden">
          <div class="flex items-center justify-between px-5 py-3 bg-gradient-to-r from-emerald-50 to-transparent border-b-2 border-emerald-100">
            <h2 class="font-display font-extrabold text-lg text-slate-900">
              <span class="inline-flex items-center justify-center w-8 h-8 rounded-xl bg-emerald-500 text-white text-sm mr-2">{{ g.code }}</span>
              Groep {{ g.code }}
            </h2>
            <span class="pill pill-grey" x-text="completionForGroup('{{ g.code }}') + ' wedstrijden'"></span>
          </div>
          <div class="grid md:grid-cols-2">
            <div class="p-5 space-y-2">
              {% for m in matches_by_group[g.code] %}
                <div class="flex items-center justify-between gap-2 py-2 border-b last:border-0 border-slate-100">
                  <div class="flex items-center gap-2 text-sm w-2/5 justify-end text-right">
                    <span class="text-slate-700 font-medium">{{ m.home_name }}</span>
                    <span class="text-xl">{{ m.home_flag }}</span>
                  </div>
                  <div class="score-pill">
                    <input type="number" min="0" max="20" name="score[{{ m.id }}][home]"
                           value="{{ m.home_goals }}"
                           @input="onScoreChange({{ m.id }}, {{ m.home_id }}, {{ m.away_id }}, '{{ g.code }}', $event)"
                           :disabled="readonly">
                    <span class="text-slate-400 font-bold">–</span>
                    <input type="number" min="0" max="20" name="score[{{ m.id }}][away]"
                           value="{{ m.away_goals }}"
                           @input="onScoreChange({{ m.id }}, {{ m.home_id }}, {{ m.away_id }}, '{{ g.code }}', $event)"
                           :disabled="readonly">
                  </div>
                  <div class="flex items-center gap-2 text-sm w-2/5">
                    <span class="text-xl">{{ m.away_flag }}</span>
                    <span class="text-slate-700 font-medium">{{ m.away_name }}</span>
                  </div>
                </div>
              {% endfor %}
            </div>

            {# Live standings #}
            <div class="p-5 bg-slate-50 border-l-2 border-slate-100">
              <div class="text-xs font-bold uppercase tracking-widest text-slate-500 mb-3">📊 Live ranking</div>
              <table class="w-full text-sm">
                <thead>
                  <tr class="text-[10px] uppercase tracking-wider text-slate-500 border-b border-slate-200">
                    <th class="text-left font-bold pb-2">#</th>
                    <th class="text-left font-bold pb-2">Team</th>
                    <th class="text-right font-bold pb-2 w-8">G</th>
                    <th class="text-right font-bold pb-2 w-12">DV</th>
                    <th class="text-right font-bold pb-2 w-10">+/-</th>
                    <th class="text-right font-bold pb-2 w-10">Pt</th>
                  </tr>
                </thead>
                <tbody>
                  <template x-for="(row, idx) in standings['{{ g.code }}']" :key="row.team_id">
                    <tr :class="idx<2 ? 'bg-emerald-50' : (idx===2 ? 'bg-amber-50' : 'bg-white')"
                        class="border-t border-slate-100">
                      <td class="py-2 pr-2 text-slate-500 font-mono font-bold" x-text="idx+1"></td>
                      <td class="py-2 pr-2 text-slate-800 font-medium" x-text="row.name"></td>
                      <td class="py-2 text-right text-slate-700" x-text="row.played"></td>
                      <td class="py-2 text-right text-slate-500 font-mono" x-text="row.gf+':'+row.ga"></td>
                      <td class="py-2 text-right text-slate-700 font-mono" x-text="(row.gd>=0?'+':'')+row.gd"></td>
                      <td class="py-2 text-right stat-number text-emerald-600" x-text="row.points"></td>
                    </tr>
                  </template>
                </tbody>
              </table>
              <div class="text-[11px] text-slate-500 mt-3 flex items-center gap-3 flex-wrap">
                <span class="inline-flex items-center gap-1.5"><span class="inline-block w-3 h-3 bg-emerald-200 rounded-sm border border-emerald-400"></span>Top 2 door</span>
                <span class="inline-flex items-center gap-1.5"><span class="inline-block w-3 h-3 bg-amber-200 rounded-sm border border-amber-400"></span>3de (mogelijk door)</span>
              </div>
            </div>
          </div>
        </div>
      {% endfor %}
    </section>

    {# ---------------- Knockout rounds ---------------- #}
    {% set koMeta = {
      'r32':  {label:'1/16 finale',  banner:'banner-blue',  emoji:'🎯'},
      'r16':  {label:'1/8 finale',   banner:'banner-blue',  emoji:'🎯'},
      'qf':   {label:'1/4 finale',   banner:'banner-orange',emoji:'🔥'},
      'sf':   {label:'Halve finale', banner:'banner-pink',  emoji:'⭐'},
      'final':{label:'De finale',    banner:'banner-green', emoji:'🏆'}
    } %}
    {% for ko, meta in koMeta %}
      <section x-show="step==='{{ ko }}'" class="space-y-4">
        {% if ko == 'final' %}
          <div class="card-thick p-6 border-emerald-400 bg-gradient-to-br from-emerald-50 to-white flex items-center gap-5">
            <div class="text-5xl">🏆</div>
            <div class="flex-1">
              <div class="text-xs uppercase tracking-widest text-emerald-700 font-bold">Wereldkampioen</div>
              <div class="font-display font-extrabold text-3xl text-emerald-700 mt-1" x-text="winnerLabel || 'Klik je winnaar aan ↓'"></div>
              <div class="text-sm text-slate-600 mt-1">De winnaar van de finale wordt automatisch jouw wereldkampioen <span class="pill pill-green ml-1">+100 pt</span></div>
            </div>
          </div>
        {% else %}
          <div class="banner {{ meta.banner }}">
            <span class="text-2xl">{{ meta.emoji }}</span>
            <span>{{ meta.label }} · klik per wedstrijd het team dat doorgaat</span>
          </div>
        {% endif %}

        <template x-if="!isGroupsComplete()">
          <div class="card p-6 flex items-start gap-4">
            <span class="text-3xl">🔒</span>
            <div>
              <div class="font-display font-extrabold text-lg text-slate-900">Nog niet beschikbaar</div>
              <p class="text-slate-600 mt-1">Vul eerst alle groepswedstrijden in om deze ronde te ontgrendelen.</p>
              <button type="button" @click="step='groups'" class="btn btn-secondary btn-sm mt-3">← Naar groepsfase</button>
            </div>
          </div>
        </template>

        <template x-if="isGroupsComplete()">
          <div class="grid sm:grid-cols-2 gap-4">
            <template x-for="match in matchesForStage('{{ ko }}')" :key="match.slot">
              <div class="card card-hover p-4">
                <div class="text-[10px] tracking-widest uppercase text-slate-400 font-bold mb-3" x-text="match.slot"></div>
                <div class="space-y-2">
                  <template x-for="side in ['home','away']" :key="side">
                    <button type="button"
                            @click="pickSlot(match.slot, match[side]?.team_id)"
                            :disabled="!match[side] || readonly"
                            :class="picks[match.slot] && match[side] && picks[match.slot]===match[side].team_id
                                       ? 'bg-emerald-500 text-white border-emerald-500 shadow-lg shadow-emerald-200'
                                       : 'bg-white hover:bg-slate-50 border-slate-200 hover:border-emerald-400 text-slate-800'"
                            class="w-full text-left px-4 py-3 rounded-2xl border-2 transition-all flex items-center justify-between disabled:opacity-40 disabled:cursor-not-allowed">
                      <span class="flex items-center gap-3">
                        <span class="text-2xl" x-text="match[side]?.flag_emoji || ''"></span>
                        <span class="font-semibold" x-text="match[side]?.name || '–'"></span>
                      </span>
                      <span class="text-[10px] uppercase tracking-wider font-bold opacity-70" x-text="match[side]?.group ? 'Groep '+match[side].group : ''"></span>
                    </button>
                  </template>
                </div>
              </div>
            </template>
          </div>
        </template>
        <template x-for="slot in slotsForStage('{{ ko }}')" :key="slot">
          <input type="hidden" :name="'slot['+slot+']'" :value="picks[slot] || ''">
        </template>
      </section>
    {% endfor %}

    {# ---------------- Topscorer ---------------- #}
    <section x-show="step==='topscorer'" class="space-y-4">
      <div class="banner banner-orange">
        <span class="text-2xl">👟</span>
        <span>Kies jouw topscorer · 10 ptn juiste speler + 3 ptn per goal</span>
      </div>

      <div class="card p-6 max-w-2xl">
        <label class="field-label">🔎 Zoek speler op naam of team</label>
        <input type="text" x-model="topscorerQuery" @input="onTopscorerInput()"
               placeholder="bv. Mbappé, Haaland, Brazilië..."
               :disabled="readonly" autocomplete="off">

        {# Live suggestions #}
        <div x-show="topscorerQuery.trim() !== ''" x-cloak class="mt-3">
          <template x-if="filteredPlayers.length === 0">
            <div class="text-sm text-slate-500 italic px-3 py-4">Geen spelers gevonden — pas je zoekterm aan.</div>
          </template>
          <template x-if="filteredPlayers.length > 0">
            <div class="space-y-1.5 max-h-72 overflow-y-auto pr-1">
              <template x-for="p in filteredPlayers" :key="p.id">
                <button type="button" @click="pickTopscorer(p)"
                        :class="topscorerPlayerId == p.id ? 'bg-emerald-500 text-white border-emerald-500' : 'bg-white hover:bg-emerald-50 border-slate-200 hover:border-emerald-300'"
                        class="w-full text-left px-4 py-3 rounded-2xl border-2 flex items-center justify-between gap-3 transition">
                  <span class="font-semibold" x-text="p.name"></span>
                  <span class="text-xs opacity-75" x-text="p.team_name || ''"></span>
                </button>
              </template>
            </div>
          </template>
        </div>

        <div class="mt-5">
          <template x-if="topscorerPlayerId">
            <div class="flex items-center justify-between gap-2 px-4 py-3 rounded-2xl bg-emerald-50 border-2 border-emerald-200">
              <div>
                <div class="text-xs uppercase tracking-widest text-emerald-700 font-bold">✓ Gekozen</div>
                <div class="font-display font-extrabold text-emerald-800 mt-0.5" x-text="topscorerLabel"></div>
              </div>
              <button type="button" @click="clearTopscorer()" class="btn btn-secondary btn-sm" :disabled="readonly">× wissen</button>
            </div>
          </template>
          <template x-if="!topscorerPlayerId">
            <p class="field-hint">Typ een naam of team om suggesties te zien, en klik je topscorer aan.</p>
          </template>
        </div>
      </div>
    </section>

    {# ---------------- Summary / submit ---------------- #}
    <section x-show="step==='summary'" class="space-y-5">
      <div class="banner banner-pink">
        <span class="text-2xl">📋</span>
        <span>Samenvatting</span>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-3">
        {% set items = [
          {label:'⚽ Groepswedstrijden', expr:"groupCompletion().filled + ' / ' + groupCompletion().total", color:'green'},
          {label:'1/16 finale', expr:"countPicks('R32') + ' / 16'", color:'blue'},
          {label:'1/8 finale',  expr:"countPicks('R16') + ' / 8'",  color:'blue'},
          {label:'1/4 finale',  expr:"countPicks('QF') + ' / 4'",   color:'orange'},
          {label:'1/2 finale',  expr:"countPicks('SF') + ' / 2'",   color:'orange'},
          {label:'🏆 Finale',   expr:"countPicks('F') + ' / 1'",    color:'pink'}
        ] %}
        {% for it in items %}
          <div class="card p-4">
            <div class="text-xs uppercase tracking-wider text-slate-500 font-bold">{{ it.label }}</div>
            <div class="stat-number text-3xl mt-1
              {% if it.color == 'green' %}text-emerald-600{% elseif it.color == 'blue' %}text-sky-600{% elseif it.color == 'orange' %}text-orange-600{% else %}text-pink-600{% endif %}"
              x-text="{{ it.expr }}"></div>
          </div>
        {% endfor %}
      </div>

      <div class="grid sm:grid-cols-2 gap-3">
        <div class="card-thick border-emerald-300 bg-gradient-to-br from-emerald-50 to-white p-5">
          <div class="text-xs uppercase tracking-wider text-emerald-700 font-bold">🏆 Wereldkampioen</div>
          <div class="font-display font-extrabold text-2xl text-emerald-700 mt-2" x-text="winnerLabel || '— nog niet gekozen —'"></div>
        </div>
        <div class="card-thick border-orange-300 bg-gradient-to-br from-orange-50 to-white p-5">
          <div class="text-xs uppercase tracking-wider text-orange-700 font-bold">👟 Topscorer</div>
          <div class="font-display font-extrabold text-2xl text-orange-700 mt-2" x-text="topscorerLabel || '— nog niet gekozen —'"></div>
        </div>
      </div>

      <div class="card-thick border-sky-300 bg-gradient-to-br from-sky-50 to-white p-5">
        <div class="flex items-center gap-3 mb-3">
          <span class="text-3xl">🎲</span>
          <div>
            <div class="text-xs uppercase tracking-wider text-sky-700 font-bold">Tiebreak</div>
            <div class="font-display font-extrabold text-lg text-sky-900">{{ settings.tiebreaker_question }}</div>
          </div>
        </div>
        <label class="field-label">Jouw antwoord (getal)</label>
        <input type="number" min="0" step="1" x-model="tiebreakerValue"
               placeholder="bv. 158" :disabled="readonly" class="max-w-xs">
        <p class="field-hint">Bij gelijke score wint wie het dichtst bij het juiste antwoord zit.</p>
      </div>

      <div class="card-thick border-amber-300 bg-amber-50 p-5 flex items-start gap-4">
        <span class="text-3xl">⚠️</span>
        <div class="flex-1">
          <div class="font-display font-extrabold text-lg text-amber-900">Belangrijk</div>
          <p class="text-amber-900 mt-1 text-sm">Na verzenden kan je je voorspelling niet meer wijzigen. Je ontvangt een PDF per mail en moet
          <strong>{{ settings.payment_amount }} {{ settings.payment_currency }}</strong>
          aan <strong>{{ settings.payment_recipient }}</strong> betalen om mee te dingen.</p>
        </div>
      </div>

      {% if not readonly %}
        <div class="flex flex-wrap gap-3 pt-2">
          <button type="submit" class="btn btn-secondary">💾 Bewaren als concept</button>
          <button type="submit" formaction="{{ url('/predictions/' ~ form.id ~ '/submit') }}"
                  onclick="return confirm('Definitief verzenden? Dit kan niet ongedaan gemaakt worden.')"
                  class="btn btn-primary">
            🚀 Definitief verzenden
          </button>
        </div>
      {% endif %}
    </section>
  </form>
</div>
{% endblock %}

{% block scripts %}
  <script>
    window.__players = {{ players|json_encode|raw }};
    window.__teamsById = {{ teams_by_id|json_encode|raw }};
    window.__initialGroupMatches = {
      {% for code, list in matches_by_group %}
        "{{ code }}": [
          {% for m in list %}
            { match_id: {{ m.id }}, home_team_id: {{ m.home_id ?: 'null' }}, away_team_id: {{ m.away_id ?: 'null' }},
              home: {{ m.home_goals is not null ? m.home_goals : 'null' }},
              away: {{ m.away_goals is not null ? m.away_goals : 'null' }} }{{ not loop.last ? ',' : '' }}
          {% endfor %}
        ]{{ not loop.last ? ',' : '' }}
      {% endfor %}
    };
  </script>
{% endblock %}
