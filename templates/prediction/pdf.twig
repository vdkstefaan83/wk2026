<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<style>
  body  { font-family: DejaVu Sans, sans-serif; font-size: 7.5pt; color: #0f172a; line-height: 1.15; margin: 0; }
  h1    { font-size: 14pt; margin: 0; }
  .sub  { font-size: 7pt; color: #475569; }

  .head { border-bottom: 1pt solid #0f172a; padding-bottom: 3pt; margin-bottom: 4pt; }
  .head td { vertical-align: middle; }

  .picks    { width: 100%; border-collapse: separate; border-spacing: 4pt 0; margin-bottom: 4pt; }
  .picks td { border: 0.75pt solid #94a3b8; border-radius: 3pt; padding: 4pt 6pt; vertical-align: top; width: 33.33%; }
  .picks .lbl { font-size: 6.5pt; text-transform: uppercase; letter-spacing: 0.04em; color: #64748b; font-weight: bold; }
  .picks .val { font-size: 10pt; font-weight: bold; }
  .picks .qst { font-size: 6.5pt; color: #475569; }

  table.outer { width: 100%; border-collapse: collapse; }
  table.outer > tbody > tr > td { vertical-align: top; width: 33.33%; padding: 0 3pt; }
  table.outer > tbody > tr > td.first { padding-left: 0; }
  table.outer > tbody > tr > td.last  { padding-right: 0; }

  .stage {
    background: #0f172a; color: #fff;
    font-size: 6.8pt; font-weight: bold;
    text-transform: uppercase; letter-spacing: 0.05em;
    padding: 2pt 4pt; margin-top: 3pt;
  }
  .stage.first { margin-top: 0; }

  table.m { width: 100%; border-collapse: collapse; border-bottom: 0.3pt solid #e2e8f0; }
  table.m td { padding: 1.8pt 2pt; font-size: 7pt; vertical-align: middle; }
  td.dt   { width: 18%; color: #64748b; font-variant-numeric: tabular-nums; white-space: nowrap; }
  td.dt .grp { color: #94a3b8; font-size: 6pt; }
  td.home { width: 36%; text-align: right; padding-right: 4pt; }
  td.away { width: 36%; text-align: left;  padding-left: 4pt; }
  td.sc   { width: 10%; text-align: center; font-weight: bold; font-size: 8.5pt; color: #0f172a; white-space: nowrap; }
  td.sc.empty { color: #cbd5e1; font-weight: normal; font-size: 7pt; }
  td.ko   { padding-left: 6pt; }
  td.ko .slot { color: #64748b; font-size: 6.5pt; margin-right: 3pt; }

  .foot { margin-top: 4pt; padding-top: 2pt; border-top: 0.3pt dashed #cbd5e1;
          font-size: 6.5pt; color: #94a3b8; text-align: center; }
</style>
</head>
<body>

  <table class="head" width="100%"><tr>
    <td>
      <h1>World Cup 2026 prediction</h1>
      <div class="sub"><b style="color:#0f172a">{{ form.label }}</b> &mdash; {{ form.user_name }} ({{ form.user_email }})</div>
    </td>
    <td align="right" class="sub">
      <b style="color:#0f172a">Submitted:</b> {{ form.submitted_at ? form.submitted_at|date('Y-m-d H:i:s') : '—' }}<br>
      <b style="color:#0f172a">File:</b> {{ filename }} &mdash; generated {{ now }}
    </td>
  </tr></table>

  <table class="picks"><tr>
    <td>
      <div class="lbl">World champion</div>
      <div class="val">{{ winner ? winner.name : '—' }}</div>
    </td>
    <td>
      <div class="lbl">Top scorer</div>
      <div class="val">{{ topscorer ? topscorer.name : '—' }}</div>
      {% if topscorer and topscorer.team_name %}<div class="qst">{{ topscorer.team_name }}</div>{% endif %}
    </td>
    <td>
      <div class="lbl">Tiebreaker</div>
      <div class="val">{{ form.tiebreaker_value is not null ? form.tiebreaker_value : '—' }}</div>
      <div class="qst">{{ settings.tiebreaker_question }}</div>
    </td>
  </tr></table>

  {% set total  = rows|length %}
  {% set perCol = (total / 3)|round(0, 'ceil') %}

  <table class="outer"><tbody><tr>
    {% for colIndex in 0..2 %}
      {% set start = colIndex * perCol %}
      {% set col = rows|slice(start, perCol) %}
      <td class="{{ colIndex == 0 ? 'first' : (colIndex == 2 ? 'last' : '') }}">
        {% set prevStage = null %}
        {% for r in col %}
          {% if r.stage != prevStage %}
            <div class="stage {% if loop.first %}first{% endif %}">
              {% if r.stage == 'group' %}Group stage
              {% elseif r.stage == 'r32' %}Round of 32
              {% elseif r.stage == 'r16' %}Round of 16
              {% elseif r.stage == 'qf' %}Quarter-finals
              {% elseif r.stage == 'sf' %}Semi-finals
              {% else %}Final{% endif %}
            </div>
            {% set prevStage = r.stage %}
          {% endif %}

          <table class="m"><tr>
            <td class="dt">{{ r.kickoff ? r.kickoff|date('m-d H:i') : '—' }}{% if r.group %} <span class="grp">·{{ r.group }}</span>{% endif %}</td>
            {% if r.stage == 'group' %}
              <td class="home">{{ r.home ? r.home.name : '—' }}</td>
              <td class="sc{% if r.pred_home is null or r.pred_away is null %} empty{% endif %}">
                {% if r.pred_home is not null and r.pred_away is not null %}{{ r.pred_home }}–{{ r.pred_away }}{% else %}—{% endif %}
              </td>
              <td class="away">{{ r.away ? r.away.name : '—' }}</td>
            {% else %}
              <td class="ko" colspan="3">
                <span class="slot">{{ r.slot }}</span><b>{{ r.pick ? r.pick.name : '—' }}</b>
              </td>
            {% endif %}
          </tr></table>
        {% endfor %}
      </td>
    {% endfor %}
  </tr></tbody></table>

  <div class="foot">
    World Cup 2026 Pool &middot; payment due {{ settings.payment_amount }} {{ settings.payment_currency }} to {{ settings.payment_recipient }}
  </div>

</body>
</html>
