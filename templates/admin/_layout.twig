{% extends 'layout/base.twig' %}

{% block content %}
<div class="flex flex-col lg:flex-row gap-6">
  <aside class="lg:w-64 shrink-0">
    <div class="card p-3 lg:sticky lg:top-20">
      <p class="px-3 pt-1 pb-2 text-xs uppercase tracking-widest text-slate-500 font-bold">Admin menu</p>
      <nav class="space-y-0.5 text-sm">
        {% set links = [
          {url:'/admin',                 label:'Overview',          icon:'📊'},
          {url:'/admin/settings',        label:'Settings',          icon:'⚙️'},
          {url:'/admin/users',           label:'Users',             icon:'👥'},
          {url:'/admin/email-templates', label:'Email templates',   icon:'✉️'},
          {url:'/admin/teams',           label:'Teams & groups',    icon:'🏳️'},
          {url:'/admin/players',         label:'Players',           icon:'👟'},
          {url:'/admin/matches',         label:'Matches',           icon:'🥅'},
          {url:'/admin/forms',           label:'Entries',           icon:'📝'},
          {url:'/admin/leaderboard',     label:'Leaderboard',       icon:'🏆'}
        ] %}
        {% for l in links %}
          {% set active = app.request_uri starts with l.url and (l.url != '/admin' or app.request_uri == '/admin') %}
          <a href="{{ url(l.url) }}"
             class="flex items-center gap-3 px-3 py-2.5 rounded-xl transition font-semibold
                    {{ active ? 'bg-emerald-500 text-white shadow-md shadow-emerald-200' : 'text-slate-700 hover:bg-slate-100' }}">
            <span class="text-base">{{ l.icon }}</span>
            <span>{{ l.label }}</span>
          </a>
        {% endfor %}
      </nav>
    </div>
  </aside>

  <section class="flex-1 min-w-0">
    {% block admin_content %}{% endblock %}
  </section>
</div>
{% endblock %}
