{% extends 'layout/base.twig' %}

{% block content %}
<div class="flex flex-col lg:flex-row gap-6">
  <aside class="lg:w-60 shrink-0">
    <div class="glass rounded-2xl p-3 lg:sticky lg:top-20">
      <p class="px-3 pt-1 pb-2 text-[10px] uppercase tracking-widest text-slate-500">Admin</p>
      <nav class="space-y-0.5 text-sm">
        {% set links = [
          {url:'/admin',                 label:'Overzicht',        icon:'📊'},
          {url:'/admin/settings',        label:'Instellingen',     icon:'⚙️'},
          {url:'/admin/email-templates', label:'E-mail templates', icon:'✉️'},
          {url:'/admin/teams',           label:'Teams & groepen',  icon:'🏳️'},
          {url:'/admin/players',         label:'Spelers',          icon:'⚽'},
          {url:'/admin/matches',         label:'Wedstrijden',      icon:'🥅'},
          {url:'/admin/forms',           label:'Formulieren',      icon:'📝'},
          {url:'/admin/leaderboard',     label:'Leaderboard',      icon:'🏆'}
        ] %}
        {% for l in links %}
          {% set active = app.request_uri starts with l.url and (l.url != '/admin' or app.request_uri == '/admin') %}
          <a href="{{ url(l.url) }}"
             class="flex items-center gap-2.5 px-3 py-2 rounded-lg transition
                    {{ active ? 'bg-gradient-to-r from-lime-400/15 to-emerald-500/10 text-lime-200 border border-lime-400/20' : 'text-slate-300 hover:bg-white/5 hover:text-white' }}">
            <span>{{ l.icon }}</span>
            <span>{{ l.label }}</span>
          </a>
        {% endfor %}
      </nav>
    </div>
  </aside>

  <section class="flex-1 min-w-0">
    {% block admin_content %}{% endblock %}
  </section>
</div>
{% endblock %}
