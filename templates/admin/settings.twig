{% extends 'admin/_layout.twig' %}
{% block admin_content %}
<p class="text-xs uppercase tracking-widest text-slate-500 font-bold">Admin</p>
<h1 class="font-display text-4xl font-extrabold mt-1 mb-6 text-slate-900">Settings</h1>

<form method="post" action="{{ url('/admin/settings') }}" class="space-y-5 max-w-2xl">
  <input type="hidden" name="_csrf" value="{{ csrf }}">

  <div class="card p-6 space-y-5">
    <div class="banner banner-blue">
      <span class="text-2xl">🔐</span>
      <span>Authentication</span>
    </div>
    <div>
      <label class="field-label">Login method</label>
      <select name="auth_provider">
        <option value="db" {{ settings.auth_provider == 'db' ? 'selected' : '' }}>Database (email + password)</option>
        <option value="keycloak" {{ settings.auth_provider == 'keycloak' ? 'selected' : '' }}>Keycloak SSO</option>
      </select>
    </div>
    <label class="flex items-center gap-2 text-sm font-medium text-slate-700">
      <input type="checkbox" name="registration_open" value="1" {{ settings.registration_open == '1' ? 'checked' : '' }}>
      Allow registrations
    </label>
  </div>

  <div class="card p-6 space-y-5">
    <div class="banner banner-green">
      <span class="text-2xl">⚽</span>
      <span>Pool</span>
    </div>
    <label class="flex items-center gap-2 text-sm font-medium text-slate-700">
      <input type="checkbox" name="predictions_open" value="1" {{ settings.predictions_open == '1' ? 'checked' : '' }}>
      Predictions open
    </label>
    <div>
      <label class="field-label">Deadline (YYYY-MM-DD HH:MM:SS)</label>
      <input name="predictions_deadline" value="{{ settings.predictions_deadline }}">
    </div>
  </div>

  <div class="card p-6 space-y-5">
    <div class="banner banner-orange">
      <span class="text-2xl">💰</span>
      <span>Payment</span>
    </div>
    <div class="grid sm:grid-cols-2 gap-4">
      <div>
        <label class="field-label">Amount</label>
        <input name="payment_amount" value="{{ settings.payment_amount }}">
      </div>
      <div>
        <label class="field-label">Currency</label>
        <input name="payment_currency" value="{{ settings.payment_currency }}">
      </div>
      <div>
        <label class="field-label">Pay to (display name)</label>
        <input name="payment_recipient" value="{{ settings.payment_recipient }}">
        <span class="field-hint">Shown in instructions ("pay X to Jonah") — first name is fine.</span>
      </div>
      <div>
        <label class="field-label">Account holder (for the QR code)</label>
        <input name="payment_recipient_name" value="{{ settings.payment_recipient_name }}" placeholder="Defaults to the name above">
        <span class="field-hint">Full beneficiary name as registered with the bank, max 70 chars. Leave blank to reuse the field above.</span>
      </div>
      <div class="sm:col-span-2">
        <label class="field-label">IBAN</label>
        <input name="payment_iban" value="{{ settings.payment_iban }}" placeholder="BE12 3456 7890 1234" class="font-mono">
        <span class="field-hint">When filled in, a SEPA QR code is generated automatically and attached to the user's confirmation email.</span>
      </div>
    </div>
    <div>
      <label class="field-label">Instructions (shown in email + after submit)</label>
      <textarea name="payment_instructions" rows="3">{{ settings.payment_instructions }}</textarea>
    </div>
  </div>

  <div class="card p-6 space-y-5">
    <div class="banner banner-pink">
      <span class="text-2xl">✉️</span>
      <span>Mail</span>
    </div>
    <div>
      <label class="field-label">Admin recipient address</label>
      <input name="admin_mail_to" value="{{ settings.admin_mail_to }}">
    </div>
  </div>

  <div class="card p-6 space-y-5">
    <div class="banner banner-pink">
      <span class="text-2xl">🏆</span>
      <span>Prizes</span>
    </div>
    <div>
      <label class="field-label">Prize distribution (one per line, format "Label: Prize")</label>
      <textarea name="prize_distribution" rows="7" class="font-mono text-sm">{{ settings.prize_distribution }}</textarea>
      <span class="field-hint">Shown on the home page, the dashboard and the wizard's summary tab. Use the "Label: Prize" format on every line.</span>
    </div>
  </div>

  <div class="card p-6 space-y-5">
    <div class="banner banner-blue">
      <span class="text-2xl">🎲</span>
      <span>Tiebreaker</span>
    </div>
    <div>
      <label class="field-label">Question (shown on the summary tab)</label>
      <textarea name="tiebreaker_question" rows="2">{{ settings.tiebreaker_question }}</textarea>
      <span class="field-hint">e.g. "How many goals will be scored in the entire tournament?"</span>
    </div>
    <div>
      <label class="field-label">Correct answer (fill in after the tournament)</label>
      <input type="number" min="0" step="1" name="tiebreaker_correct_value" value="{{ settings.tiebreaker_correct_value }}" class="max-w-xs">
      <span class="field-hint">Used to break ties in the leaderboard. May stay empty until after the final.</span>
    </div>
  </div>

  <button class="btn btn-primary">💾 Save</button>
</form>
{% endblock %}
