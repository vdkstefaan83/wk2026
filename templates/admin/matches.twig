{% extends 'admin/_layout.twig' %}
{% block admin_content %}
<div class="flex flex-wrap items-end justify-between gap-3 mb-6">
  <div>
    <p class="text-xs uppercase tracking-widest text-slate-500 font-bold">Admin</p>
    <h1 class="font-display text-4xl font-extrabold mt-1 text-slate-900">Matches</h1>
  </div>
  <div class="flex items-center gap-2 text-sm flex-wrap">
    <form method="post" action="{{ url('/admin/sync-matches') }}" class="flex items-center gap-2">
      <input type="hidden" name="_csrf" value="{{ csrf }}">
      <label class="flex items-center gap-1.5 text-xs text-slate-700">
        <input type="checkbox" name="topscorer" value="1"> + top scorer
      </label>
      <button class="btn btn-primary btn-sm">↻ Sync</button>
    </form>
    <form method="post" action="{{ url('/admin/sync-debug') }}" class="inline">
      <input type="hidden" name="_csrf" value="{{ csrf }}">
      <button class="btn btn-secondary btn-sm" title="Show what the web context fetches">🔍 Debug</button>
    </form>
    {% if settings.last_sync_at %}
      <span class="text-xs text-slate-500">last sync: {{ settings.last_sync_at }}</span>
    {% endif %}
  </div>
</div>

<div class="flex flex-wrap gap-1 mb-4 text-sm">
  {% for s in ['group','r32','r16','qf','sf','final'] %}
    <a href="{{ url('/admin/matches?stage=' ~ s) }}"
       class="px-3 py-1.5 rounded-lg border-2 transition text-xs uppercase tracking-wider font-bold
              {{ stage == s ? 'bg-emerald-500 border-emerald-500 text-white' : 'bg-white border-slate-200 text-slate-600 hover:border-emerald-300' }}">
      {{ {'group':'Group stage','r32':'R32','r16':'R16','qf':'QF','sf':'SF','final':'Final'}[s] }}
    </a>
  {% endfor %}
</div>

<form method="post" action="{{ url('/admin/matches') }}">
  <input type="hidden" name="_csrf" value="{{ csrf }}">
  <input type="hidden" name="stage" value="{{ stage }}">
  <div class="card overflow-x-auto">
    <table class="w-full text-sm min-w-[800px]">
      <thead class="bg-slate-50 border-b-2 border-slate-100">
        <tr class="text-xs uppercase tracking-wider text-slate-500 font-bold">
          <th class="p-2 text-left">#</th>
          <th class="p-2 text-left">Group</th>
          <th class="p-2 text-left">Home</th>
          <th class="p-2 text-left">Away</th>
          <th class="p-2 text-left">Kick-off</th>
          <th class="p-2 text-left">Venue</th>
          <th class="p-2 text-center" colspan="2">Actual score</th>
        </tr>
      </thead>
      <tbody>
        {% for m in matches %}
          <tr class="border-t border-slate-100">
            <td class="p-2 text-slate-500 font-mono">{{ m.match_number }}</td>
            <td class="p-2 text-emerald-700">{{ m.group_code ?? '' }}</td>
            <td class="p-2">
              <select name="match[{{ m.id }}][home_team_id]" class="w-44 px-2 py-1.5">
                <option value="">—</option>
                {% for t in teams %}<option value="{{ t.id }}" {{ m.home_team_id == t.id ? 'selected' : '' }}>{{ t.name }}</option>{% endfor %}
              </select>
            </td>
            <td class="p-2">
              <select name="match[{{ m.id }}][away_team_id]" class="w-44 px-2 py-1.5">
                <option value="">—</option>
                {% for t in teams %}<option value="{{ t.id }}" {{ m.away_team_id == t.id ? 'selected' : '' }}>{{ t.name }}</option>{% endfor %}
              </select>
            </td>
            <td class="p-2"><input name="match[{{ m.id }}][kickoff_at]" value="{{ m.kickoff_at }}" placeholder="YYYY-MM-DD HH:MM" class="w-40 px-2 py-1.5"></td>
            <td class="p-2"><input name="match[{{ m.id }}][venue]" value="{{ m.venue }}" class="w-40 px-2 py-1.5"></td>
            <td class="p-2"><input type="number" min="0" max="20" name="match[{{ m.id }}][actual_home_goals]" value="{{ m.actual_home_goals }}" class="w-16 px-2 py-1.5 text-center"></td>
            <td class="p-2"><input type="number" min="0" max="20" name="match[{{ m.id }}][actual_away_goals]" value="{{ m.actual_away_goals }}" class="w-16 px-2 py-1.5 text-center"></td>
          </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
  <button class="mt-4 btn btn-primary">💾 Save</button>
</form>
{% endblock %}
