{% extends 'admin/_layout.twig' %}
{% block admin_content %}
<h1 class="text-2xl font-bold mb-4">Template: <span class="font-mono">{{ template.key }}</span></h1>
<form method="post" action="{{ url('/admin/email-templates/' ~ template.key) }}" class="space-y-4 max-w-3xl bg-white rounded-xl border border-slate-200 p-5">
  <input type="hidden" name="_csrf" value="{{ csrf }}">
  <div>
    <label class="text-sm font-medium">Onderwerp</label>
    <input name="subject" value="{{ template.subject }}" class="mt-1 w-full rounded border-slate-300">
  </div>
  <div>
    <label class="text-sm font-medium">Body (HTML)</label>
    <div id="editor" style="height: 280px;">{{ template.body_html|raw }}</div>
    <textarea name="body_html" id="body_html" hidden>{{ template.body_html }}</textarea>
  </div>
  <button class="px-4 py-2 rounded bg-indigo-600 text-white hover:bg-indigo-700">Bewaren</button>
  <a href="{{ url('/admin/email-templates') }}" class="ml-2 text-sm text-slate-500 hover:underline">Terug</a>
</form>
{% endblock %}

{% block head %}
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/quill@2.0.2/dist/quill.snow.css">
{% endblock %}

{% block scripts %}
<script src="https://cdn.jsdelivr.net/npm/quill@2.0.2/dist/quill.min.js"></script>
<script>
  const quill = new Quill('#editor', {
    theme: 'snow',
    modules: { toolbar: [
      [{header:[1,2,3,false]}],
      ['bold','italic','underline','link'],
      [{list:'ordered'},{list:'bullet'}],
      ['clean']
    ]}
  });
  const ta = document.getElementById('body_html');
  document.querySelector('form').addEventListener('submit', () => {
    ta.value = quill.root.innerHTML;
  });
</script>
{% endblock %}
