{% extends 'admin/_layout.twig' %}
{% block admin_content %}
<p class="text-xs uppercase tracking-widest text-slate-500 font-bold">Admin · template</p>
<h1 class="font-display text-3xl font-extrabold mt-1 mb-6">
  <span class="font-mono text-emerald-700">{{ template.key }}</span>
</h1>

<form method="post" action="{{ url('/admin/email-templates/' ~ template.key) }}" class="space-y-4 max-w-3xl">
  <input type="hidden" name="_csrf" value="{{ csrf }}">
  <div class="card p-6 space-y-4">
    <div>
      <label class="field-label">Subject</label>
      <input name="subject" value="{{ template.subject }}">
    </div>
    <div>
      <label class="field-label">Body (HTML)</label>
      <div id="editor" class="mt-1">{{ template.body_html|raw }}</div>
      <textarea name="body_html" id="body_html" hidden>{{ template.body_html }}</textarea>
    </div>
  </div>
  <div class="flex gap-2">
    <button class="btn btn-primary">💾 Save</button>
    <a href="{{ url('/admin/email-templates') }}" class="btn btn-secondary">← Back</a>
  </div>
</form>
{% endblock %}

{% block head %}
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/quill@2.0.2/dist/quill.snow.css">
{% endblock %}

{% block scripts %}
<script src="https://cdn.jsdelivr.net/npm/quill@2.0.2/dist/quill.min.js"></script>
<script>
  const quill = new Quill('#editor', {
    theme: 'snow',
    modules: { toolbar: [
      [{header:[1,2,3,false]}],
      ['bold','italic','underline','link'],
      [{list:'ordered'},{list:'bullet'}],
      ['clean']
    ]}
  });
  const ta = document.getElementById('body_html');
  document.querySelector('form').addEventListener('submit', () => {
    ta.value = quill.root.innerHTML;
  });
</script>
{% endblock %}
