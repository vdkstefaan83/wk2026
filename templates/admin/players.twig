{% extends 'admin/_layout.twig' %}
{% block admin_content %}
<h1 class="text-2xl font-bold mb-4">Spelers (topscorer-keuze)</h1>

<form method="post" action="{{ url('/admin/players') }}" class="bg-white rounded-xl border border-slate-200 p-4 mb-4">
  <input type="hidden" name="_csrf" value="{{ csrf }}">
  <h2 class="font-semibold mb-2">Nieuwe speler</h2>
  <div class="flex gap-2">
    <input name="new[name]" placeholder="Naam" class="rounded border-slate-300 flex-1">
    <select name="new[team_id]" class="rounded border-slate-300">
      <option value="">— team —</option>
      {% for t in teams %}<option value="{{ t.id }}">{{ t.name }}</option>{% endfor %}
    </select>
    <button class="px-4 py-2 rounded bg-emerald-500 text-white hover:bg-emerald-600">Toevoegen</button>
  </div>
</form>

<form method="post" action="{{ url('/admin/players') }}">
  <input type="hidden" name="_csrf" value="{{ csrf }}">
  <div class="bg-white rounded-xl border border-slate-200 overflow-hidden">
    <table class="w-full text-sm">
      <thead class="bg-slate-50">
        <tr><th class="p-2 text-left">Speler</th><th class="p-2 text-left w-48">Team</th><th class="p-2 w-20"></th></tr>
      </thead>
      <tbody>
        {% for p in players %}
          <tr class="border-t border-slate-100">
            <td class="p-2"><input name="player[{{ p.id }}][name]" value="{{ p.name }}" class="w-full rounded border-slate-300"></td>
            <td class="p-2">
              <select name="player[{{ p.id }}][team_id]" class="w-full rounded border-slate-300">
                <option value="">—</option>
                {% for t in teams %}<option value="{{ t.id }}" {{ p.team_id == t.id ? 'selected' : '' }}>{{ t.name }}</option>{% endfor %}
              </select>
            </td>
            <td class="p-2 text-right">
              <button name="delete" value="{{ p.id }}" onclick="return confirm('Speler verwijderen?')"
                      class="text-rose-600 hover:underline">verwijder</button>
            </td>
          </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
  <button class="mt-4 px-4 py-2 rounded bg-indigo-600 text-white hover:bg-indigo-700">Bewaren</button>
</form>
{% endblock %}
