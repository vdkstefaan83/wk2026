{% extends 'admin/_layout.twig' %}
{% block admin_content %}
<p class="text-xs uppercase tracking-widest text-slate-500 font-bold">Admin</p>
<h1 class="font-display text-4xl font-extrabold mt-1 mb-8 text-slate-900">Overview</h1>

<div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
  {% set tiles = [
    {label:'Users',     value: stats.users,           icon:'👥', color:'green'},
    {label:'Entries',   value: stats.forms_total,     icon:'📝', color:'blue'},
    {label:'Submitted', value: stats.forms_submitted, icon:'✅', color:'orange'},
    {label:'Paid',      value: stats.forms_paid,      icon:'💰', color:'pink'}
  ] %}
  {% for t in tiles %}
    <div class="card card-hover p-5">
      <div class="flex items-center justify-between">
        <div class="text-xs uppercase tracking-widest text-slate-500 font-bold">{{ t.label }}</div>
        <span class="inline-flex items-center justify-center w-10 h-10 rounded-xl text-xl
          {% if t.color == 'green' %}bg-emerald-50{% elseif t.color == 'blue' %}bg-sky-50{% elseif t.color == 'orange' %}bg-orange-50{% else %}bg-pink-50{% endif %}">
          {{ t.icon }}
        </span>
      </div>
      <div class="stat-number text-5xl mt-3
        {% if t.color == 'green' %}text-emerald-600{% elseif t.color == 'blue' %}text-sky-600{% elseif t.color == 'orange' %}text-orange-600{% else %}text-pink-600{% endif %}">
        {{ t.value }}
      </div>
    </div>
  {% endfor %}
</div>
{% endblock %}
