{% extends 'admin/_layout.twig' %}
{% block admin_content %}
<h1 class="text-2xl font-bold mb-4">Formulieren & betalingen</h1>
<div class="bg-white rounded-xl border border-slate-200 overflow-x-auto">
  <table class="w-full text-sm">
    <thead class="bg-slate-50">
      <tr>
        <th class="p-2 text-left">Gebruiker</th>
        <th class="p-2 text-left">Formulier</th>
        <th class="p-2 text-left">Status</th>
        <th class="p-2 text-left">Verzonden</th>
        <th class="p-2 text-left">Betaling</th>
        <th class="p-2 text-left">PDF</th>
        <th class="p-2"></th>
      </tr>
    </thead>
    <tbody>
      {% for f in forms %}
        <tr class="border-t border-slate-100">
          <td class="p-2">
            <div class="font-medium">{{ f.user_name }}</div>
            <div class="text-xs text-slate-500">{{ f.user_email }}</div>
          </td>
          <td class="p-2">{{ f.label }}</td>
          <td class="p-2">
            {% if f.status == 'submitted' %}
              <span class="text-emerald-700">verzonden</span>
            {% else %}
              <span class="text-slate-500">concept</span>
            {% endif %}
          </td>
          <td class="p-2">{{ f.submitted_at ? f.submitted_at|date('d/m/Y H:i') : '—' }}</td>
          <td class="p-2">
            {% if f.paid_at %}
              <span class="text-emerald-700">✓ {{ f.paid_amount }} op {{ f.paid_at|date('d/m/Y') }}</span><br>
              <span class="text-xs text-slate-500">{{ f.paid_note }}</span>
            {% else %}
              <span class="text-amber-700">openstaand</span>
            {% endif %}
          </td>
          <td class="p-2">{{ f.pdf_path ? '✓' : '—' }}</td>
          <td class="p-2">
            <form method="post" action="{{ url('/admin/forms/' ~ f.id ~ '/payment') }}" class="flex flex-col gap-1">
              <input type="hidden" name="_csrf" value="{{ csrf }}">
              <label class="text-xs"><input type="checkbox" name="paid" value="1" {{ f.paid_at ? 'checked' : '' }}> betaald</label>
              <input name="amount" value="{{ f.paid_amount ?: settings.payment_amount }}" class="text-xs rounded border-slate-300 w-20">
              <input name="note" value="{{ f.paid_note }}" placeholder="notitie" class="text-xs rounded border-slate-300">
              <button class="text-xs px-2 py-1 rounded bg-indigo-600 text-white hover:bg-indigo-700">save</button>
            </form>
          </td>
        </tr>
      {% endfor %}
    </tbody>
  </table>
</div>
{% endblock %}
