{% extends 'admin/_layout.twig' %}
{% block admin_content %}
<p class="text-xs uppercase tracking-widest text-slate-500 font-bold">Admin</p>
<h1 class="font-display text-4xl font-extrabold mt-1 mb-6 text-slate-900">Entries & payments</h1>

<div class="card overflow-x-auto">
  <table class="w-full text-sm">
    <thead class="bg-slate-50 border-b-2 border-slate-100">
      <tr class="text-xs uppercase tracking-wider text-slate-500 font-bold">
        <th class="p-3 text-left">User</th>
        <th class="p-3 text-left">Form</th>
        <th class="p-3 text-left">Status</th>
        <th class="p-3 text-left">Submitted</th>
        <th class="p-3 text-left">Payment</th>
        <th class="p-3 text-left">PDF</th>
        <th class="p-3"></th>
      </tr>
    </thead>
    <tbody>
      {% for f in forms %}
        <tr class="border-t border-slate-100">
          <td class="p-3">
            <div class="font-semibold text-slate-900">{{ f.user_name }}</div>
            <div class="text-xs text-slate-500">{{ f.user_email }}</div>
          </td>
          <td class="p-3 text-slate-700">{{ f.label }}</td>
          <td class="p-3">
            {% if f.status == 'submitted' %}
              <span class="pill pill-green">Submitted</span>
            {% else %}
              <span class="pill pill-grey">Draft</span>
            {% endif %}
          </td>
          <td class="p-3 text-slate-700">{{ f.submitted_at ? f.submitted_at|date('Y-m-d H:i') : '—' }}</td>
          <td class="p-3">
            {% if f.paid_at %}
              <span class="text-emerald-700 font-semibold">✓ {{ f.paid_amount }} on {{ f.paid_at|date('Y-m-d') }}</span><br>
              <span class="text-xs text-slate-500">{{ f.paid_note }}</span>
            {% else %}
              <span class="text-orange-700 font-semibold">outstanding</span>
            {% endif %}
          </td>
          <td class="p-3 text-slate-700">{{ f.pdf_path ? '✓' : '—' }}</td>
          <td class="p-3">
            <form method="post" action="{{ url('/admin/forms/' ~ f.id ~ '/payment') }}" class="flex flex-col gap-1">
              <input type="hidden" name="_csrf" value="{{ csrf }}">
              <label class="text-xs text-slate-700 flex items-center gap-1 font-medium">
                <input type="checkbox" name="paid" value="1" {{ f.paid_at ? 'checked' : '' }}> paid
              </label>
              <input name="amount" value="{{ f.paid_amount ?: settings.payment_amount }}" class="text-xs w-20 px-1.5 py-1">
              <input name="note" value="{{ f.paid_note }}" placeholder="note" class="text-xs px-1.5 py-1">
              <button class="btn btn-primary btn-sm">save</button>
            </form>
          </td>
        </tr>
      {% endfor %}
    </tbody>
  </table>
</div>
{% endblock %}
