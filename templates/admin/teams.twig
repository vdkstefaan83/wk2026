{% extends 'admin/_layout.twig' %}
{% block admin_content %}
<h1 class="text-2xl font-bold mb-4">Teams & groepen</h1>
<form method="post" action="{{ url('/admin/teams') }}">
  <input type="hidden" name="_csrf" value="{{ csrf }}">
  <div class="bg-white rounded-xl border border-slate-200 overflow-hidden">
    <table class="w-full text-sm">
      <thead class="bg-slate-50">
        <tr>
          <th class="text-left p-2">Naam</th>
          <th class="text-left p-2 w-20">ISO3</th>
          <th class="text-left p-2 w-24">Vlag</th>
          <th class="text-left p-2 w-32">Groep</th>
        </tr>
      </thead>
      <tbody>
        {% for t in teams %}
          <tr class="border-t border-slate-100">
            <td class="p-2"><input name="team[{{ t.id }}][name]" value="{{ t.name }}" class="w-full rounded border-slate-300"></td>
            <td class="p-2"><input name="team[{{ t.id }}][iso3]" value="{{ t.iso3 }}" class="w-full rounded border-slate-300"></td>
            <td class="p-2"><input name="team[{{ t.id }}][flag_emoji]" value="{{ t.flag_emoji }}" class="w-full rounded border-slate-300"></td>
            <td class="p-2">
              <select name="team[{{ t.id }}][group_id]" class="w-full rounded border-slate-300">
                <option value="">—</option>
                {% for g in groups %}
                  <option value="{{ g.id }}" {{ t.group_id == g.id ? 'selected' : '' }}>Groep {{ g.code }}</option>
                {% endfor %}
              </select>
            </td>
          </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
  <button class="mt-4 px-4 py-2 rounded bg-indigo-600 text-white hover:bg-indigo-700">Bewaren</button>
</form>
{% endblock %}
