{% extends 'admin/_layout.twig' %}
{% block admin_content %}
<p class="text-xs uppercase tracking-wider text-slate-500">Admin</p>
<h1 class="font-display text-3xl font-extrabold mt-1 mb-6">Teams & groepen</h1>

<form method="post" action="{{ url('/admin/teams') }}">
  <input type="hidden" name="_csrf" value="{{ csrf }}">
  <div class="glass rounded-2xl overflow-x-auto">
    <table class="w-full text-sm">
      <thead class="bg-white/[0.03] border-b border-white/5">
        <tr>
          <th class="text-left p-3 text-xs uppercase tracking-wider text-slate-400">Naam</th>
          <th class="text-left p-3 text-xs uppercase tracking-wider text-slate-400 w-20">ISO3</th>
          <th class="text-left p-3 text-xs uppercase tracking-wider text-slate-400 w-24">Vlag</th>
          <th class="text-left p-3 text-xs uppercase tracking-wider text-slate-400 w-32">Groep</th>
        </tr>
      </thead>
      <tbody>
        {% for t in teams %}
          <tr class="border-t border-white/5">
            <td class="p-2"><input name="team[{{ t.id }}][name]" value="{{ t.name }}" class="w-full px-2 py-1.5"></td>
            <td class="p-2"><input name="team[{{ t.id }}][iso3]" value="{{ t.iso3 }}" class="w-full px-2 py-1.5 font-mono"></td>
            <td class="p-2"><input name="team[{{ t.id }}][flag_emoji]" value="{{ t.flag_emoji }}" class="w-full px-2 py-1.5 text-center"></td>
            <td class="p-2">
              <select name="team[{{ t.id }}][group_id]" class="w-full px-2 py-1.5">
                <option value="">—</option>
                {% for g in groups %}
                  <option value="{{ g.id }}" {{ t.group_id == g.id ? 'selected' : '' }}>Groep {{ g.code }}</option>
                {% endfor %}
              </select>
            </td>
          </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
  <button class="mt-4 btn-neon">💾 Bewaren</button>
</form>
{% endblock %}
