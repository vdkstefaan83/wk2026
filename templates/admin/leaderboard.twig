{% extends 'admin/_layout.twig' %}
{% block admin_content %}
<div class="flex items-center justify-between mb-6">
  <div>
    <p class="text-xs uppercase tracking-widest text-slate-500 font-bold">Admin</p>
    <h1 class="font-display text-4xl font-extrabold mt-1 text-slate-900">Leaderboard 🏆</h1>
  </div>
  <form method="post" action="{{ url('/admin/recompute') }}">
    <input type="hidden" name="_csrf" value="{{ csrf }}">
    <button class="btn btn-secondary btn-sm">↻ Recalculate</button>
  </form>
</div>

<div class="flex flex-wrap items-center justify-between gap-3 mb-4">
  <div class="flex gap-2">
    <a href="{{ url('/admin/leaderboard') }}"
       class="px-4 py-2 rounded-lg border-2 transition text-sm font-bold
              {{ not show_all ? 'bg-emerald-500 border-emerald-500 text-white' : 'bg-white border-slate-200 text-slate-600 hover:border-emerald-300' }}">
      💰 Paid only ({{ counts.paid }})
    </a>
    <a href="{{ url('/admin/leaderboard?all=1') }}"
       class="px-4 py-2 rounded-lg border-2 transition text-sm font-bold
              {{ show_all ? 'bg-slate-700 border-slate-700 text-white' : 'bg-white border-slate-200 text-slate-600 hover:border-slate-400' }}">
      All submitted ({{ counts.paid + counts.unpaid }})
    </a>
  </div>
  <p class="text-xs text-slate-500">
    {% if not show_all %}
      Points are only awarded to paid entries. <strong>{{ counts.unpaid }}</strong> submitted entr{{ counts.unpaid == 1 ? 'y' : 'ies' }} not shown (no payment yet).
    {% else %}
      Showing all submitted entries — unpaid ones are <span class="text-amber-700 font-semibold">marked</span> but do not qualify for prizes.
    {% endif %}
  </p>
</div>

{% if correct_tiebreak %}
  <p class="text-sm text-slate-600 mb-3 flex items-center gap-2">
    <span class="pill pill-blue">🎲 Tiebreaker: {{ correct_tiebreak }}</span>
    <span>tied scores are broken by smallest deviation.</span>
  </p>
{% endif %}

<div class="card overflow-hidden">
  <table class="w-full text-sm">
    <thead class="bg-slate-50 border-b-2 border-slate-100">
      <tr class="text-xs uppercase tracking-wider text-slate-500 font-bold">
        <th class="p-3 text-left w-16">#</th>
        <th class="p-3 text-left">User</th>
        <th class="p-3 text-left">Form</th>
        <th class="p-3 text-left hidden md:table-cell">🏆 Champion</th>
        <th class="p-3 text-left hidden md:table-cell">👟 Top scorer</th>
        <th class="p-3 text-right">Score</th>
        <th class="p-3 text-right">Tiebreaker</th>
        <th class="p-3 text-left">Paid</th>
      </tr>
    </thead>
    <tbody>
      {% for r in rows %}
        <tr class="border-t border-slate-100 {{ not r.paid_at ? 'opacity-60' : '' }}">
          <td class="p-3 font-display font-extrabold text-center">
            {% if loop.index == 1 %}<span class="text-2xl">🥇</span>
            {% elseif loop.index == 2 %}<span class="text-2xl">🥈</span>
            {% elseif loop.index == 3 %}<span class="text-2xl">🥉</span>
            {% else %}<span class="text-slate-500">{{ loop.index }}</span>
            {% endif %}
          </td>
          <td class="p-3">
            <div class="text-slate-900 font-semibold">{{ r.user_name }}</div>
            <div class="text-xs text-slate-500">{{ r.user_email }}</div>
          </td>
          <td class="p-3 text-slate-700">{{ r.label }}</td>
          <td class="p-3 text-slate-700 hidden md:table-cell">{{ r.winner_team ?: '—' }}</td>
          <td class="p-3 text-slate-700 hidden md:table-cell">{{ r.topscorer_name ?: '—' }}</td>
          <td class="p-3 text-right stat-number text-2xl text-emerald-600">{{ r.score }}</td>
          <td class="p-3 text-right text-slate-700">
            {% if r.tiebreaker_value is not null %}
              <span class="font-mono">{{ r.tiebreaker_value }}</span>
              {% if r.tiebreak_diff is not null %}
                <span class="text-xs text-slate-500">(±{{ r.tiebreak_diff }})</span>
              {% endif %}
            {% else %}<span class="text-slate-400">—</span>{% endif %}
          </td>
          <td class="p-3">
            {% if r.paid_at %}
              <span class="pill pill-green">✓ paid</span>
            {% else %}
              <span class="pill pill-orange">⏳ unpaid</span>
            {% endif %}
          </td>
        </tr>
      {% endfor %}
    </tbody>
  </table>
</div>
{% endblock %}
