{% extends 'admin/_layout.twig' %}
{% block admin_content %}
<div class="flex items-center justify-between mb-6">
  <div>
    <p class="text-xs uppercase tracking-wider text-slate-500">Admin</p>
    <h1 class="font-display text-3xl font-extrabold mt-1">Leaderboard 🏆</h1>
  </div>
  <form method="post" action="{{ url('/admin/recompute') }}">
    <input type="hidden" name="_csrf" value="{{ csrf }}">
    <button class="btn-ghost text-xs">↻ Herberekenen</button>
  </form>
</div>

<div class="glass rounded-2xl overflow-hidden">
  <table class="w-full text-sm">
    <thead class="bg-white/[0.03] border-b border-white/5">
      <tr class="text-xs uppercase tracking-wider text-slate-400">
        <th class="p-3 text-left w-16">#</th>
        <th class="p-3 text-left">Gebruiker</th>
        <th class="p-3 text-left">Formulier</th>
        <th class="p-3 text-right">Score</th>
        <th class="p-3 text-left">Betaald</th>
      </tr>
    </thead>
    <tbody>
      {% for r in rows %}
        <tr class="border-t border-white/5 hover:bg-white/[0.02]">
          <td class="p-3 font-display font-extrabold">
            {% if loop.index == 1 %}<span class="text-2xl">🥇</span>
            {% elseif loop.index == 2 %}<span class="text-2xl">🥈</span>
            {% elseif loop.index == 3 %}<span class="text-2xl">🥉</span>
            {% else %}<span class="text-slate-500">{{ loop.index }}</span>
            {% endif %}
          </td>
          <td class="p-3">
            <div class="text-slate-100 font-medium">{{ r.user_name }}</div>
            <div class="text-xs text-slate-500">{{ r.user_email }}</div>
          </td>
          <td class="p-3 text-slate-300">{{ r.label }}</td>
          <td class="p-3 text-right font-display text-2xl font-extrabold text-gradient">{{ r.score }}</td>
          <td class="p-3">{{ r.paid_at ? '✓' : '—' }}</td>
        </tr>
      {% endfor %}
    </tbody>
  </table>
</div>
{% endblock %}
