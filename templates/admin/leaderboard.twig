{% extends 'admin/_layout.twig' %}
{% block admin_content %}
<div class="flex items-center justify-between mb-6">
  <div>
    <p class="text-xs uppercase tracking-wider text-slate-500">Admin</p>
    <h1 class="font-display text-3xl font-extrabold mt-1">Leaderboard 🏆</h1>
  </div>
  <form method="post" action="{{ url('/admin/recompute') }}">
    <input type="hidden" name="_csrf" value="{{ csrf }}">
    <button class="btn-ghost text-xs">↻ Herberekenen</button>
  </form>
</div>

{% if correct_tiebreak %}
  <p class="text-sm text-slate-600 mb-3 flex items-center gap-2">
    <span class="pill pill-blue">🎲 Tiebreak: {{ correct_tiebreak }}</span>
    <span>gelijke scores worden gescheiden op kleinste afwijking.</span>
  </p>
{% endif %}

<div class="card overflow-hidden">
  <table class="w-full text-sm">
    <thead class="bg-slate-50 border-b-2 border-slate-100">
      <tr class="text-xs uppercase tracking-wider text-slate-500 font-bold">
        <th class="p-3 text-left w-16">#</th>
        <th class="p-3 text-left">Gebruiker</th>
        <th class="p-3 text-left">Formulier</th>
        <th class="p-3 text-right">Score</th>
        <th class="p-3 text-right">Tiebreak</th>
        <th class="p-3 text-left">Betaald</th>
      </tr>
    </thead>
    <tbody>
      {% for r in rows %}
        <tr class="border-t border-slate-100">
          <td class="p-3 font-display font-extrabold text-center">
            {% if loop.index == 1 %}<span class="text-2xl">🥇</span>
            {% elseif loop.index == 2 %}<span class="text-2xl">🥈</span>
            {% elseif loop.index == 3 %}<span class="text-2xl">🥉</span>
            {% else %}<span class="text-slate-500">{{ loop.index }}</span>
            {% endif %}
          </td>
          <td class="p-3">
            <div class="text-slate-900 font-semibold">{{ r.user_name }}</div>
            <div class="text-xs text-slate-500">{{ r.user_email }}</div>
          </td>
          <td class="p-3 text-slate-700">{{ r.label }}</td>
          <td class="p-3 text-right stat-number text-2xl text-emerald-600">{{ r.score }}</td>
          <td class="p-3 text-right text-slate-700">
            {% if r.tiebreaker_value is not null %}
              <span class="font-mono">{{ r.tiebreaker_value }}</span>
              {% if r.tiebreak_diff is not null %}
                <span class="text-xs text-slate-500">(±{{ r.tiebreak_diff }})</span>
              {% endif %}
            {% else %}<span class="text-slate-400">—</span>{% endif %}
          </td>
          <td class="p-3">{{ r.paid_at ? '✓' : '—' }}</td>
        </tr>
      {% endfor %}
    </tbody>
  </table>
</div>
{% endblock %}
