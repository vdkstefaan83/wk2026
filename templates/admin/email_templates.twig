{% extends 'admin/_layout.twig' %}
{% block admin_content %}
<p class="text-xs uppercase tracking-widest text-slate-500 font-bold">Admin</p>
<h1 class="font-display text-4xl font-extrabold mt-1 mb-6 text-slate-900">Email templates</h1>

<div class="card overflow-hidden">
  <table class="w-full text-sm">
    <thead class="bg-slate-50 border-b-2 border-slate-100">
      <tr>
        <th class="text-left p-3 text-xs uppercase tracking-wider text-slate-500 font-bold">Key</th>
        <th class="text-left p-3 text-xs uppercase tracking-wider text-slate-500 font-bold">Subject</th>
        <th class="p-3"></th>
      </tr>
    </thead>
    <tbody>
      {% for t in templates %}
        <tr class="border-t border-slate-100">
          <td class="p-3 font-mono text-emerald-700">{{ t.key }}</td>
          <td class="p-3 text-slate-900">{{ t.subject }}</td>
          <td class="p-3 text-right">
            <a href="{{ url('/admin/email-templates/' ~ t.key) }}" class="btn btn-secondary btn-sm">Edit →</a>
          </td>
        </tr>
      {% endfor %}
    </tbody>
  </table>
</div>

<p class="text-xs text-slate-500 mt-4">
  Placeholders: <code class="text-slate-700">{{ '{{user_name}}' }}</code>, <code class="text-slate-700">{{ '{{user_email}}' }}</code>,
  <code class="text-slate-700">{{ '{{form_label}}' }}</code>, <code class="text-slate-700">{{ '{{submitted_at}}' }}</code>,
  <code class="text-slate-700">{{ '{{payment_amount}}' }}</code>, <code class="text-slate-700">{{ '{{payment_currency}}' }}</code>,
  <code class="text-slate-700">{{ '{{payment_recipient}}' }}</code>, <code class="text-slate-700">{{ '{{payment_instructions}}' }}</code>.
</p>
{% endblock %}
