{% extends 'admin/_layout.twig' %}
{% block admin_content %}
<p class="text-xs uppercase tracking-wider text-slate-500">Admin</p>
<h1 class="font-display text-3xl font-extrabold mt-1 mb-6">E-mail templates</h1>

<div class="glass rounded-2xl overflow-hidden">
  <table class="w-full text-sm">
    <thead class="bg-white/[0.03] border-b border-white/5">
      <tr>
        <th class="text-left p-3 text-xs uppercase tracking-wider text-slate-400">Key</th>
        <th class="text-left p-3 text-xs uppercase tracking-wider text-slate-400">Onderwerp</th>
        <th class="p-3"></th>
      </tr>
    </thead>
    <tbody>
      {% for t in templates %}
        <tr class="border-t border-white/5 hover:bg-white/[0.03]">
          <td class="p-3 font-mono text-lime-300">{{ t.key }}</td>
          <td class="p-3 text-slate-200">{{ t.subject }}</td>
          <td class="p-3 text-right">
            <a href="{{ url('/admin/email-templates/' ~ t.key) }}" class="btn-ghost text-xs">Bewerken →</a>
          </td>
        </tr>
      {% endfor %}
    </tbody>
  </table>
</div>

<p class="text-xs text-slate-500 mt-4">
  Placeholders: <code class="text-slate-300">{{ '{{user_name}}' }}</code>, <code class="text-slate-300">{{ '{{user_email}}' }}</code>,
  <code class="text-slate-300">{{ '{{form_label}}' }}</code>, <code class="text-slate-300">{{ '{{submitted_at}}' }}</code>,
  <code class="text-slate-300">{{ '{{payment_amount}}' }}</code>, <code class="text-slate-300">{{ '{{payment_currency}}' }}</code>,
  <code class="text-slate-300">{{ '{{payment_recipient}}' }}</code>, <code class="text-slate-300">{{ '{{payment_instructions}}' }}</code>.
</p>
{% endblock %}
