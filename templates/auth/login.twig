{% extends 'layout/base.twig' %}
{% block title %}Inloggen · {{ app.name }}{% endblock %}
{% block content %}
<div class="max-w-md mx-auto mt-10">
  <div class="glass rounded-3xl p-8 relative overflow-hidden">
    <div class="absolute -top-12 -right-12 w-40 h-40 rounded-full bg-lime-400/15 blur-3xl pointer-events-none"></div>

    <h1 class="font-display text-3xl font-extrabold text-slate-100">Welkom terug</h1>
    <p class="text-sm text-slate-400 mt-1">Log in om je voorspellingen verder in te vullen.</p>

    {% if settings.auth_provider == 'keycloak' and keycloak %}
      <a href="{{ url('/auth/keycloak/login') }}" class="mt-6 btn-neon w-full text-center inline-flex items-center justify-center gap-2">
        Inloggen met Keycloak SSO →
      </a>
      <p class="text-xs text-slate-500 mt-4 text-center">DB-login uitgeschakeld door de beheerder.</p>
    {% else %}
      <form method="post" action="{{ url('/login') }}" class="space-y-4 mt-6">
        <input type="hidden" name="_csrf" value="{{ csrf }}">
        <div>
          <label class="text-xs uppercase tracking-wider font-medium">E-mail</label>
          <input name="email" type="email" required autofocus value="{{ old('email') }}" class="mt-1 w-full px-3 py-2.5">
        </div>
        <div>
          <label class="text-xs uppercase tracking-wider font-medium">Wachtwoord</label>
          <input name="password" type="password" required class="mt-1 w-full px-3 py-2.5">
        </div>
        <button class="btn-neon w-full mt-2">Inloggen</button>
      </form>
      {% if settings.registration_open == '1' %}
        <p class="text-sm text-slate-400 mt-6 text-center">
          Nog geen account?
          <a href="{{ url('/register') }}" class="text-lime-400 hover:text-lime-300 font-medium">Registreer hier</a>
        </p>
      {% endif %}
    {% endif %}
  </div>
</div>
{% endblock %}
