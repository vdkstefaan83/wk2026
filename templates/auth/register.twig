{% extends 'layout/base.twig' %}
{% block title %}Registreren · {{ app.name }}{% endblock %}
{% block content %}
<div class="max-w-md mx-auto mt-10">
  <div class="card-thick p-8">
    <div class="banner banner-blue mb-6">
      <span class="text-2xl">🎉</span>
      <span>Account aanmaken</span>
    </div>

    <form method="post" action="{{ url('/register') }}" class="space-y-5">
      <input type="hidden" name="_csrf" value="{{ csrf }}">
      <div>
        <label class="field-label">👤 Naam</label>
        <input name="name" type="text" required value="{{ old('name') }}" placeholder="Voornaam Achternaam">
      </div>
      <div>
        <label class="field-label">📧 E-mailadres</label>
        <input name="email" type="email" required value="{{ old('email') }}" placeholder="jij@example.com">
      </div>
      <div>
        <label class="field-label">🔑 Wachtwoord</label>
        <input name="password" type="password" minlength="8" required placeholder="minstens 8 tekens">
        <span class="field-hint">Kies een wachtwoord van minstens 8 tekens.</span>
      </div>
      <button class="btn btn-primary w-full">Registreren →</button>
    </form>

    <p class="text-sm text-slate-600 mt-6 text-center">
      Reeds een account?
      <a href="{{ url('/login') }}" class="text-emerald-600 hover:text-emerald-700 font-bold">Inloggen</a>
    </p>
  </div>
</div>
{% endblock %}
