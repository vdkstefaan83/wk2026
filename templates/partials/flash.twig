{% if flash is not empty %}
  <div class="space-y-2 mb-4">
    {% for type, list in flash %}
      {% for msg in list %}
        <div class="px-4 py-2 rounded border text-sm
          {% if type == 'success' %}bg-emerald-50 border-emerald-300 text-emerald-800
          {% elseif type == 'error' %}bg-rose-50 border-rose-300 text-rose-800
          {% elseif type == 'info'  %}bg-sky-50 border-sky-300 text-sky-800
          {% else %}bg-slate-50 border-slate-300 text-slate-800{% endif %}">
          {{ msg|raw }}
        </div>
      {% endfor %}
    {% endfor %}
  </div>
{% endif %}
