{% if flash is not empty %}
  <div class="space-y-2 mb-6">
    {% for type, list in flash %}
      {% for msg in list %}
        <div class="px-4 py-3 rounded-xl border text-sm backdrop-blur
          {% if type == 'success' %}bg-emerald-500/10 border-emerald-400/30 text-emerald-200
          {% elseif type == 'error' %}bg-rose-500/10 border-rose-400/30 text-rose-200
          {% elseif type == 'info' %}bg-sky-500/10 border-sky-400/30 text-sky-200
          {% else %}bg-white/5 border-white/10 text-slate-200{% endif %}">
          {{ msg|raw }}
        </div>
      {% endfor %}
    {% endfor %}
  </div>
{% endif %}
