{% if flash is not empty %}
  <div class="space-y-2 mb-6">
    {% for type, list in flash %}
      {% for msg in list %}
        <div class="px-4 py-3 rounded-2xl border-2 text-sm font-medium flex items-start gap-2
          {% if type == 'success' %}bg-emerald-50 border-emerald-200 text-emerald-900
          {% elseif type == 'error' %}bg-rose-50 border-rose-200 text-rose-900
          {% elseif type == 'info'  %}bg-sky-50 border-sky-200 text-sky-900
          {% else %}bg-slate-50 border-slate-200 text-slate-800{% endif %}">
          <span class="text-base">
            {% if type == 'success' %}✅{% elseif type == 'error' %}⚠️{% elseif type == 'info' %}ℹ️{% else %}💬{% endif %}
          </span>
          <span>{{ msg|raw }}</span>
        </div>
      {% endfor %}
    {% endfor %}
  </div>
{% endif %}
